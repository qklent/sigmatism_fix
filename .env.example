# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download OmniVoice (k2-fsa/OmniVoice) and GigaAM-v3 (ai-sage/GigaAM-v3).
# Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: relocate the HF cache (large model weights). Defaults to ~/.cache/huggingface.
# HF_HOME=/workspace/.cache/huggingface

# ── Triton / serving (optional — only when driving a remote Triton server) ───
# TRITON_URL=localhost:8000        # HTTP endpoint of the Triton Inference Server
# TRITON_GRPC_URL=localhost:8001   # gRPC endpoint

# ── GitHub (optional — used by setup_pod.sh for non-interactive clone) ───────
# GITHUB_TOKEN=
